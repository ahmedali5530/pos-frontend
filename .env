VITE_WEBSITE_NAME=POS
VITE_APP_ADDRESS="Hawks Bay Area"
VITE_API_HOST=https://api.pos.ezportal.online
VITE_API_BASE_URL=$VITE_API_HOST/api
VITE_BASE_URL=

VITE_CURRENCY=PKR
VITE_LOCALE=en-PK
VITE_DECIMAL_PLACES=0
#valid options are "frontend", "admin"
VITE_APP_TYPE=frontend

VITE_DATE_FORMAT="dd-MM-yyyy"
VITE_TIME_FORMAT="hh:mm a"
VITE_DATE_TIME_FORMAT="${VITE_DATE_FORMAT} ${VITE_TIME_FORMAT}"
VITE_DATE_TIME_HUMAN_FORMAT="ff"
VITE_SURREAL_DB_DATE_TIME_FORMAT="yyyy-MM-dd'T'HH:mm:ss'Z'"
VITE_GOOGLE_ANALYTICS=

VITE_DB_WEBDOCKET=ws://localhost:8001
VITE_PRINT_SERVER_PORT=3132
VITE_PRINT_SERVER_HOST="http://localhost:${VITE_PRINT_SERVER_PORT}"
